{
  "name": "green-riverside-cosy-home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/fix-static-html-lang.mjs",
    "start": "node scripts/serve-static.mjs out",
    "lint": "eslint src next.config.ts eslint.config.mjs postcss.config.mjs --ext .ts,.tsx,.mjs",
    "firebase:login": "firebase login",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes --project green-riverside-cosy-home",
    "firebase:deploy:storage": "firebase deploy --only storage --project green-riverside-cosy-home",
    "firebase:rules-console": "powershell -ExecutionPolicy Bypass -File scripts/deploy-rules.ps1",
    "backup:firestore": "node --env-file=.env.local scripts/backup-firestore.mjs",
    "seed": "npm run seed:auth",
    "seed:auth": "node --env-file=.env.local scripts/seed-via-auth.mjs",
    "site:sync": "node --env-file=.env.local scripts/sync-site-content.mjs",
    "rooms:sync": "node --env-file=.env.local scripts/sync-room-catalog.mjs",
    "rooms:restore-images": "node --env-file=.env.local scripts/restore-room-images-from-metadata.mjs",
    "rooms:restore-storage-images": "node --env-file=.env.local scripts/restore-room-images-from-storage.mjs",
    "import:tours:docx": "node --env-file=.env.local scripts/import-paradise-phongnha-tours.mjs",
    "import:tours:classic": "node --env-file=.env.local scripts/import-classic-duck-farm-tours.mjs",
    "import:tours:vietnam": "node --env-file=.env.local scripts/import-other-vietnam-tours.mjs",
    "import:tours:jungle-boss": "node --env-file=.env.local scripts/import-jungle-boss-tour-details.mjs",
    "images:tours:prepare": "node --env-file=.env.local scripts/prepare-tour-image-workspace.mjs",
    "images:tours": "node --env-file=.env.local scripts/bulk-upload-tour-images.mjs",
    "images:fetch": "node scripts/fetch-sample-images.mjs",
    "images:banner": "node scripts/fetch-banner.mjs",
    "doc:brochure": "node scripts/generate-brand-brochure.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.0.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "docx": "^9.7.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "firebase-tools": "^15.20.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
